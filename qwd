local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- [[ 1. FUNGSI PENCARI REMOTE (ANTI-ERROR) ]] --
local AttackRemote
local function FindAttackRemote()
    if AttackRemote then return AttackRemote end
    -- Mencari di lokasi umum Blox Fruits tanpa WaitForChild yang bikin macet
    local net = ReplicatedStorage:FindFirstChild("Modules") and ReplicatedStorage.Modules:FindFirstChild("Net")
    if net then
        local re = net:FindFirstChild("RE") or net:FindFirstChild("RemoteEvents")
        if re then
            AttackRemote = re:FindFirstChild("Attack")
        end
    end
    return AttackRemote
end

local MainRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_")

