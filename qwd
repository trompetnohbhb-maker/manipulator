local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- KONFIGURASI
local AimSettings = {
    Enabled = true,
    AimPart = "Head",
    FOV_Radius = 200, -- Ukuran lingkaran FOV
    AimKey = Enum.UserInputType.MouseButton1 -- Klik Kiri
}

-- [[ 1. VISUALISASI FOV (LINGKARAN) ]] --
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Color = Color3.fromRGB(255, 255, 255) -- Warna Putih
FOVCircle.Transparency = 1
FOVCircle.Filled = false
FOVCircle.Visible = true
FOVCircle.Radius = AimSettings.FOV_Radius

-- [[ 2. ESP STABIL (LOGIKA ASLI KAMU) ]] --
local function buatESP(player)
    player.CharacterAdded:Connect(function(char)
        if player == LocalPlayer then return end
        local root = char:WaitForChild("HumanoidRootPart", 10) 
        if root then
            if root:FindFirstChild("KotakESP") then root.KotakESP:Destroy() end
            local gui = Instance.new("BillboardGui", root)
            gui.Name = "KotakESP"
            gui.AlwaysOnTop = true
            gui.Size = UDim2.new(4, 0, 5.5, 0)
            local frame = Instance.new("Frame", gui)
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 0.6
            frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            local stroke = Instance.new("UIStroke", frame)
            stroke.Thickness = 2
            stroke.Color = Color3.fromRGB(255, 255, 255)
        end
    end)
end

-- [[ 3. LOGIKA INSTANT AIM ]] --
local function getClosestPlayer()
    local target = nil
    local shortestDistance = AimSettings.FOV_Radius

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(AimSettings.AimPart) then
            local part = player.Character[AimSettings.AimPart]
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            
            if onScreen then
                local mousePos = UserInputService:GetMouseLocation()
                local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                
                if distance < shortestDistance then
                    target = part
                    shortestDistance = distance
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    -- Update posisi dan visibilitas lingkaran FOV
    FOVCircle.Position = UserInputService:GetMouseLocation()
    FOVCircle.Radius = AimSettings.FOV_Radius
    
    if AimSettings.Enabled and UserInputService:IsMouseButtonPressed(AimSettings.AimKey) then
        local target = getClosestPlayer()
        if target then
            -- INSTANT LOCK (Tanpa Smooth)
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        end
    end
end)

-- Jalankan ESP
for _, p in pairs(Players:GetPlayers()) do
    if p.Character then buatESP(p) end
    buatESP(p)
end
Players.PlayerAdded:Connect(buatESP)
