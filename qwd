_G.AutoAttack = false
_G.AttackRange = false
_G.FlyAbove = false
_G.AutoQuest = false

local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
if PlayerGui:FindFirstChild("YutaHub_Final") then PlayerGui.YutaHub_Final:Destroy() end

-- [[ 2. SETUP UI ]] --
local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "YutaHub_Final"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 160, 0, 260)
MainFrame.Position = UDim2.new(0.5, -80, 0.4, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

local Header = Instance.new("TextLabel", MainFrame)
Header.Size = UDim2.new(1, 0, 0, 40)
Header.Text = "YUTA HUB FINAL"
Header.TextColor3 = Color3.fromRGB(255, 255, 255)
Header.BackgroundColor3 = Color3.fromRGB(130, 0, 0)
Header.Font = Enum.Font.SourceSansBold
Header.TextSize = 16
Instance.new("UICorner", Header).CornerRadius = UDim.new(0, 10)

-- Drag System
local dragging, dragStart, startPos
Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)

local ButtonHolder = Instance.new("Frame", MainFrame)
ButtonHolder.Size = UDim2.new(1, 0, 1, -45); ButtonHolder.Position = UDim2.new(0, 0, 0, 45); ButtonHolder.BackgroundTransparency = 1
local Layout = Instance.new("UIListLayout", ButtonHolder); Layout.Padding = UDim.new(0, 7); Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

local function CreateButton(name, order, callback)
    local btn = Instance.new("TextButton", ButtonHolder)
    btn.Size = UDim2.new(0.9, 0, 0, 40); btn.LayoutOrder = order; btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); btn.TextColor3 = Color3.fromRGB(255, 255, 255); btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.Text = name .. (active and ": ON" or ": OFF")
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
        callback(active)
    end)
end

-- [[ 3. LOGIKA CORE ]] --

local function GetEnemy()
    local target = nil
    local dist = 500
    local folder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Characters")
    if folder then
        for _, v in pairs(folder:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                local mag = (v.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if mag < dist then dist = mag; target = v end
            end
        end
    end
    return target
end

-- A. AUTO ATTACK (HYBRID - CLICK + ACTIVATE)
CreateButton("Auto Attack", 1, function(state)
    _G.AutoAttack = state
    task.spawn(function()
        while _G.AutoAttack do
            RunService.RenderStepped:Wait()
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool then
                    -- Metode 1: Klik Virtual
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton1(Vector2.new(0,0))
                    -- Metode 2: Paksa Aktifkan Tool
                    tool:Activate()
                end
            end)
        end
    end)
end)

-- B. ATTACK RANGE (ULTRA HITBOX)
CreateButton("Attack Range", 2, function(state)
    _G.AttackRange = state
    task.spawn(function()
        while _G.AttackRange do
            task.wait(0.5)
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChild("Handle") then
                    tool.Handle.Size = Vector3.new(60, 60, 60)
                    tool.Handle.Transparency = 0.8
                    tool.Handle.CanCollide = false
                end
            end)
        end
    end)
end)

-- C. FLY ABOVE NPC (TINGGI 15 UNIT)
CreateButton("Fly Above NPC", 3, function(state)
    _G.FlyAbove = state
    task.spawn(function()
        while _G.FlyAbove do
            RunService.Heartbeat:Wait()
            pcall(function()
                local target = GetEnemy()
                local root = LocalPlayer.Character.HumanoidRootPart
                if target and root then
                    -- Melayang di ketinggian 15 unit
                    root.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 15, 0)
                end
            end)
        end
    end)
end)

-- D. AUTO QUEST
CreateButton("Auto Quest", 4, function(state)
    _G.AutoQuest = state
    task.spawn(function()
        local comm = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_")
        while _G.AutoQuest do
            if comm and not LocalPlayer.PlayerGui.Main.Quest.Visible then
                comm:InvokeServer("StartQuest", "BanditQuest1", 1)
            end
            task.wait(1.5)
        end
    end)
end)
