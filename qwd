if PlayerGui:FindFirstChild("RonixBlox_Final") then PlayerGui.RonixBlox_Final:Destroy() end

local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "RonixBlox_Final"
