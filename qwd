local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Fungsi Utama Bikin Hantu
local function makeGhost()
    local char = LocalPlayer.Character
    if char then
        for _, v in pairs(char:GetDescendants()) do
            -- Bikin semua bagian tubuh, baju 3D, dan aksesoris jadi transparan
            if v:IsA("BasePart") or v:IsA("Decal") or v:IsA("MeshPart") then
                if v.Name ~= "HumanoidRootPart" then
                    v.Transparency = 1
                end
            end
            -- Hapus baju klasik biar bener-bener bersih
            if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("GraphicTShirt") then
                v:Destroy()
            end
        end
    end
end

-- Jalankan terus-menerus (Anti-Reset Visual)
-- Biar kalo game maksa karakter muncul, script ini maksa ilangin lagi
RunService.RenderStepped:Connect(makeGhost)

print("Invis Berhasil! Kamu sekarang jadi hantu permanen.")
