-- [[ 1. DATA QUEST LENGKAP (SEA 1) ]] --
local function GetQuestData()
    local lv = LocalPlayer.Data.Level.Value
    if lv < 10 then return "BanditQuest1", 1
    elseif lv < 15 then return "MonkeyQuest1", 1
    elseif lv < 30 then return "MonkeyQuest1", 2
    elseif lv < 40 then return "PirateIslandQuest", 1
    elseif lv < 60 then return "PirateIslandQuest", 2
    elseif lv < 75 then return "DesertIslandQuest", 1
    elseif lv < 90 then return "DesertIslandQuest", 2
    elseif lv < 120 then return "SnowIslandQuest", 1
    elseif lv < 150 then return "SnowIslandQuest", 2
    elseif lv < 175 then return "MarineTreeQuest", 1
    elseif lv < 190 then return "MarineTreeQuest", 2
    elseif lv < 210 then return "SkyQuest", 1
    elseif lv < 250 then return "SkyQuest", 2
    elseif lv < 275 then return "PrisonQuest", 1
    elseif lv < 300 then return "PrisonQuest", 2
    elseif lv < 330 then return "MagmaQuest", 1
    elseif lv < 425 then return "MagmaQuest", 2
    elseif lv < 450 then return "FishmanQuest", 1
    elseif lv < 575 then return "FishmanQuest", 2
    elseif lv < 625 then return "SkyExp1Quest", 1
    elseif lv < 700 then return "SkyExp1Quest", 2
    else return "BanditQuest1", 1 end
end

-- [[ 2. SETUP UI YUTA HUB 7 ]] --
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
if PlayerGui:FindFirstChild("YutaHub_V7") then PlayerGui.YutaHub_V7:Destroy() end

local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "YutaHub_V7"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 160, 0, 260)
MainFrame.Position = UDim2.new(0.5, -80, 0.4, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

local Header = Instance.new("TextLabel", MainFrame)
Header.Size = UDim2.new(1, 0, 0, 40)
Header.Text = "YUTA HUB 7"
Header.TextColor3 = Color3.fromRGB(255, 255, 255)
Header.BackgroundColor3 = Color3.fromRGB(130, 0, 0)
Header.Font = Enum.Font.SourceSansBold
Header.TextSize = 16
Instance.new("UICorner", Header).CornerRadius = UDim.new(0, 10)

-- Drag System
local dragging, dragStart, startPos
Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)

local ButtonHolder = Instance.new("Frame", MainFrame)
ButtonHolder.Size = UDim2.new(1, 0, 1, -45); ButtonHolder.Position = UDim2.new(0, 0, 0, 45); ButtonHolder.BackgroundTransparency = 1
local Layout = Instance.new("UIListLayout", ButtonHolder); Layout.Padding = UDim.new(0, 7); Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

local function CreateButton(name, order, callback)
    local btn = Instance.new("TextButton", ButtonHolder)
    btn.Size = UDim2.new(0.9, 0, 0, 40); btn.LayoutOrder = order; btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); btn.TextColor3 = Color3.fromRGB(255, 255, 255); btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.Text = name .. (active and ": ON" or ": OFF")
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
        callback(active)
    end)
end

-- [[ 3. ULTRA FAST ATTACK LOGIC ]] --
local function GetEnemy()
    local folder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Characters")
    for _, v in pairs(folder:GetChildren()) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and (v.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 100 then
            return v
        end
    end
end

local function SuperAttack()
    pcall(function()
        local Net = ReplicatedStorage.Modules.Net:FindFirstChild("RE/Attack") or ReplicatedStorage.Modules.Net:FindFirstChild("Attack")
        if Net then
            -- Extreme Spam 4x Hit
            Net:FireServer(0.12)
            Net:FireServer(0.12)
            Net:FireServer(0.12)
            Net:FireServer(0.12)
        end
    end)
end

