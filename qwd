-- ATTACK RANGE (Memperbesar Hitbox - Lebih Aman dari Mob Pull)
_G.Range = false
CreateButton("Attack Range", 2, function(state)
    _G.Range = state
    while _G.Range do
        task.wait(0.5)
        pcall(function()
            local folder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Characters")
            for _, v in pairs(folder:GetChildren()) do
                if v:FindFirstChild("HumanoidRootPart") then
                    v.HumanoidRootPart.Size = _G.Range and Vector3.new(30, 30, 30) or Vector3.new(2, 2, 1)
                    v.HumanoidRootPart.Transparency = _G.Range and 0.8 or 0
                    v.HumanoidRootPart.CanCollide = false
                end
            end
        end)
    end
end)

-- FLY ABOVE NPC (Tinggi 8 Unit / Pas 3 NPC)
