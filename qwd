local function GetQuestData()
    local lv = LocalPlayer.Data.Level.Value
    if lv < 10 then return "BanditQuest1", 1
    elseif lv < 15 then return "MonkeyQuest1", 1
    elseif lv < 30 then return "MonkeyQuest1", 2
    elseif lv < 40 then return "PirateIslandQuest", 1
    elseif lv < 60 then return "PirateIslandQuest", 2
    elseif lv < 75 then return "DesertIslandQuest", 1
    elseif lv < 90 then return "DesertIslandQuest", 2
    elseif lv < 120 then return "SnowIslandQuest", 1
    elseif lv < 150 then return "SnowIslandQuest", 2
    elseif lv < 175 then return "MarineTreeQuest", 1
    elseif lv < 190 then return "MarineTreeQuest", 2
    elseif lv < 210 then return "SkyQuest", 1
    elseif lv < 250 then return "SkyQuest", 2
    elseif lv < 275 then return "PrisonQuest", 1
    elseif lv < 300 then return "PrisonQuest", 2
    elseif lv < 330 then return "MagmaQuest", 1
    elseif lv < 425 then return "MagmaQuest", 2
    elseif lv < 450 then return "FishmanQuest", 1
    elseif lv < 575 then return "FishmanQuest", 2
    elseif lv < 625 then return "SkyExp1Quest", 1
    elseif lv < 700 then return "SkyExp1Quest", 2
    else return "BanditQuest1", 1 end
end

