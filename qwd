local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local Camera = workspace.CurrentCamera

-- KONFIGURASI
local _G.SilentAimEnabled = true
local _G.AimPart = "Head" -- Bisa ganti "HumanoidRootPart"
local _G.FieldOfView = 300 -- Radius kuncian

-- [[ 1. LOGIKA SILENT AIM (HOOK MOUSE) ]] --
local function getClosestPlayer()
    local target = nil
    local shortestDistance = _G.FieldOfView

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(_G.AimPart) then
            local pos, onScreen = Camera:WorldToViewportPoint(player.Character[_G.AimPart].Position)
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if distance < shortestDistance then
                    target = player.Character[_G.AimPart]
                    shortestDistance = distance
                end
            end
        end
    end
    return target
end

-- Hook Metatable (Ini inti dari Silent Aim agar peluru belok)
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if _G.SilentAimEnabled and method == "FindPartOnRayWithIgnoreList" or method == "Raycast" then
        local target = getClosestPlayer()
        if target then
            -- Membelokkan arah tembakan ke target
            return oldNamecall(self, Ray.new(Camera.CFrame.Position, (target.Position - Camera.CFrame.Position).Unit * 1000), args[2])
        end
    end
    return oldNamecall(self, ...)
end)

setreadonly(mt, true)

-- [[ 2. ESP STABIL (LOGIKA ASLI KAMU) ]] --
local function buatESP(player)
    player.CharacterAdded:Connect(function(char)
        if player == LocalPlayer then return end
        local root = char:WaitForChild("HumanoidRootPart", 10) 
        if root then
            if root:FindFirstChild("KotakESP") then root.KotakESP:Destroy() end
            local gui = Instance.new("BillboardGui", root)
            gui.Name = "KotakESP"
            gui.AlwaysOnTop = true
            gui.Size = UDim2.new(4, 0, 5.5, 0)
            local frame = Instance.new("Frame", gui)
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 0.6
            frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            local stroke = Instance.new("UIStroke", frame)
            stroke.Thickness = 2
            stroke.Color = Color3.fromRGB(255, 255, 255)
        end
    end)
end

for _, p in pairs(Players:GetPlayers()) do
    if p.Character then buatESP(p) end
    buatESP(p)
end
Players.PlayerAdded:Connect(buatESP)
