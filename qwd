-- [[ FUNGSI CARI REMOTE AMAN ]] --
local function GetCommF()
    return ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_")
end

local function GetAttackRemote()
    -- Coba cari di folder Modules/Net/RE/Attack (Standard Blox Fruit)
    local path = ReplicatedStorage:FindFirstChild("Modules")
    if path then
        path = path:FindFirstChild("Net")
        if path then
            path = path:FindFirstChild("RE")
            if path then
                return path:FindFirstChild("Attack")
            end
        end
    end
    return nil
end

