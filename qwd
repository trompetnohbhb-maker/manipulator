local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Fungsi Invisible Total
local function sailorInvis()
    local char = LocalPlayer.Character
    if char then
        -- Menghapus semua part visual
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("Decal") or v:IsA("MeshPart") or v:IsA("Texture") then
                if v.Name ~= "HumanoidRootPart" then
                    v.Transparency = 1
                end
            end
            -- Menghilangkan Armor, Jubah, dan Aksesoris One Piece
            if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("Clothing") then
                v:Destroy()
            end
            -- Menghilangkan partikel buah iblis (efek aura)
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = false
            end
        end
    end
end

-- Menjalankan secara berulang (Supaya tidak muncul lagi saat ganti item)
local connection = RunService.RenderStepped:Connect(sailorInvis)

-- Pesan untuk memastikan script jalan
print("Sailor Piece Invisible Aktif!")
