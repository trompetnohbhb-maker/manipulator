local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

-- Fungsi khusus buat hilangin badan tanpa ganggu jalan
local function murniInvis()
    local char = player.Character
    if char then
        -- Reset HipHeight biar nggak tenggelam (Fix bug tenggelam)
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then 
            hum.HipHeight = 0 
        end
        
        for _, v in pairs(char:GetDescendants()) do
            -- Hanya ubah transparansi, jangan hapus part utama
            if v:IsA("BasePart") or v:IsA("Decal") then
                if v.Name ~= "HumanoidRootPart" then
                    v.Transparency = 1
                end
            end
            -- Hapus aksesoris/baju yang bikin kelihatan
            if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") then
                v:Destroy()
            end
        end
    end
end

-- Pakai task.spawn biar nggak berat di Ronix
task.spawn(function()
    while task.wait(1) do -- Cukup cek setiap 1 detik biar nggak lag
        murniInvis()
    end
end)

print("Invis Normal Aktif! Jalan harusnya sudah nggak error lagi.")
