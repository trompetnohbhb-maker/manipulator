local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function buatESP(player)
    local function applyESP(char)
        if player == LocalPlayer then return end
        
        -- Menunggu HumanoidRootPart atau Head (Universal Check)
        local root = char:WaitForChild("HumanoidRootPart", 10) or char:WaitForChild("Head", 10)
        
        if root then
            -- Hapus jika sudah ada agar tidak tumpuk
            if root:FindFirstChild("KotakESP") then root.KotakESP:Destroy() end

            local gui = Instance.new("BillboardGui")
            gui.Name = "KotakESP"
            gui.AlwaysOnTop = true
            gui.Size = UDim2.new(4, 0, 5.5, 0)
            gui.Adornee = root
            gui.Parent = root

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 0.6
            frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            frame.BorderSizePixel = 0
            frame.Parent = gui
            
            local stroke = Instance.new("UIStroke")
            stroke.Thickness = 2
            stroke.Color = Color3.fromRGB(255, 255, 255)
            stroke.Parent = frame
        end
    end

    if player.Character then applyESP(player.Character) end
    player.CharacterAdded:Connect(applyESP)
end

-- Menjalankan untuk semua pemain di server
for _, p in pairs(Players:GetPlayers()) do
    task.spawn(function()
        buatESP(p)
    end)
end

Players.PlayerAdded:Connect(buatESP)
