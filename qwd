-- Auto Attack
CreateButton("Auto Attack", 1, function(state)
    _G.AA = state
    task.spawn(function()
        while _G.AA do
            local remote = FindAttackRemote()
            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if remote and tool then
                remote:FireServer(0.1)
                tool:Activate()
            end
            task.wait(0.1)
        end
    end)
end)

