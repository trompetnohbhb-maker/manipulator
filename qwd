end)

-- B. Attack Range (Mob Pull)
CreateButton("Attack Range", 2, function(state)
    _G.Range = state
    task.spawn(function()
        while _G.Range do
            RunService.Heartbeat:Wait()
            pcall(function()
                local enemy = GetEnemy()
                if enemy and _G.AutoAttack then
                    enemy.HumanoidRootPart.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, -10, 0)
                    enemy.HumanoidRootPart.CanCollide = false
                end
            end)
        end
    end)
end)

-- C. Fly Above NPC (Tinggi 25 + Anti Gravity)
CreateButton("Fly Above NPC", 3, function(state)
    _G.Fly = state
    task.spawn(function()
        while _G.Fly do
            RunService.Heartbeat:Wait()
            pcall(function()
                local target = GetEnemy()
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if target and root then
                    if not root:FindFirstChild("YutaG") then
                        local bv = Instance.new("BodyVelocity", root)
                        bv.Name = "YutaG"
                        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                        bv.Velocity = Vector3.new(0,0,0)
                    end
                    root.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 25, 0)
                end
            end)
        end
        if LocalPlayer.Character.HumanoidRootPart:FindFirstChild("YutaG") then
            LocalPlayer.Character.HumanoidRootPart.YutaG:Destroy()
        end
    end)
end)

