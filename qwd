local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local espEnabled = true -- Ubah jadi false kalau mau dimatikan

local function buatESP(player)
    player.CharacterAdded:Connect(function(char)
        local root = char:WaitForChild("HumanoidRootPart")
        
        -- 1. Membuat Box (Kotak di badan pemain)
        local highlight = Instance.new("Highlight")
        highlight.Name = "PlayerESP"
        highlight.Parent = char
        highlight.FillTransparency = 0.6 -- Transparansi kotak
        highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Merah untuk musuh
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- Putih untuk garis tepi
        
        -- 2. Membuat Nama & Jarak (BillboardGui)
        local gui = Instance.new("BillboardGui")
        gui.Name = "TagESP"
        gui.Size = UDim2.new(0, 100, 0, 50)
        gui.AlwaysOnTop = true
        gui.StudsOffset = Vector3.new(0, 3, 0)
        gui.Parent = root

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = player.Name
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextStrokeTransparency = 0
        label.Parent = gui
    end)
end

-- Jalankan fungsi untuk semua pemain yang masuk
for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        buatESP(p)
    end
end

Players.PlayerAdded:Connect(buatESP)
