Header.TextSize = 14
Header.Active = true
Instance.new("UICorner", Header).CornerRadius = UDim.new(0, 8)

-- [[ 2. SISTEM DRAG & COLLAPSE ]] --
local dragging, dragStart, startPos, dragDistance
local collapsed = false

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragDistance = 0
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        dragDistance = delta.Magnitude
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local ContentFrame = Instance.new("Frame", MainFrame)
ContentFrame.Size = UDim2.new(1, 0, 1, -45)
ContentFrame.Position = UDim2.new(0, 0, 0, 40)
ContentFrame.BackgroundTransparency = 1
local Layout = Instance.new("UIListLayout", ContentFrame)
Layout.Padding = UDim.new(0, 5)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            dragging = false
            if dragDistance < 5 then
                collapsed = not collapsed
                -- Animasi tutup menyesuaikan ukuran baru
                MainFrame:TweenSize(collapsed and UDim2.new(0, 160, 0, 35) or UDim2.new(0, 160, 0, 260), "Out", "Quad", 0.2, true)
                ContentFrame.Visible = not collapsed
            end
        end
    end
end)

-- [[ 3. FUNGSI TOMBOL ]] --
local function CreateButton(name, order, callback)
    local btn = Instance.new("TextButton", ContentFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 40) -- Tombol sedikit lebih besar agar enak di-klik
    btn.LayoutOrder = order
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 13
    Instance.new("UICorner", btn)

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.Text = name .. (active and ": ON" or ": OFF")
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
        callback(active)
    end)
end

-- [[ 4. LOGIKA FITUR ]] --

local function GetNearestEnemy()
    local target = nil
    local dist = math.huge
    local folder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Characters")
    if folder then
        for _, v in pairs(folder:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                local magnitude = (v.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if magnitude < dist then
                    dist = magnitude
                    target = v
                end
            end
        end
    end
    return target
end

-- 1. Auto Attack
local FastAttack = false
CreateButton("Auto Attack", 1, function(state)
    FastAttack = state
    task.spawn(function()
        while FastAttack do
            local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool then
                AttackRemote:FireServer(0.1)
                AttackRemote:FireServer(0.1)
                tool:Activate()
            end
            task.wait(0.1)
        end
    end)
end)

-- 2. Attack Range (Memperbesar Hitbox)
local RangeActive = false
CreateButton("Attack Range", 2, function(state)
    RangeActive = state
    task.spawn(function()
        while RangeActive do
            pcall(function()
                local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChild("Handle") then
                    tool.Handle.Size = Vector3.new(20, 20, 20) -- Jangkauan jadi besar
                    tool.Handle.Transparency = 0.8
                end
            end)
            task.wait(1)
        end
    end)
end)

-- 3. Fly Above NPC
local FlyNPC = false
CreateButton("Fly Above NPC", 3, function(state)
    FlyNPC = state
    task.spawn(function()
        while FlyNPC do
            local enemy = GetNearestEnemy()
            if enemy and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = enemy.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)
            end
            task.wait()
        end
    end)
end)

-- 4. Auto Quest
local function GetQuestData()
    local level = LocalPlayer.Data.Level.Value
    if level >= 0 and level < 10 then return "BanditQuest1", 1
    elseif level >= 10 and level < 15 then return "MonkeyQuest1", 1
    elseif level >= 15 and level < 30 then return "MonkeyQuest1", 2
    elseif level >= 30 and level < 40 then return "PirateIslandQuest", 1
    elseif level >= 40 and level < 60 then return "PirateIslandQuest", 2
    else return "BanditQuest1", 1 end
end

local AutoQuest = false
CreateButton("Auto Quest", 4, function(state)
    AutoQuest = state
    task.spawn(function()
        while AutoQuest do
            if not LocalPlayer.PlayerGui.Main:FindFirstChild("Quest") or LocalPlayer.PlayerGui.Main.Quest.Visible == false then
                local qName, qId = GetQuestData()
                MainRemote:InvokeServer("StartQuest", qName, qId)
            end
            task.wait(1)
        end
    end)
end)

