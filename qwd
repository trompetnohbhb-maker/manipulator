end)

CreateButton("Fly Above NPC", 3, function(state)
    print("Fly: " .. tostring(state))
end)

CreateButton("Auto Quest", 4, function(state)
    print("Quest: " .. tostring(state))
end)

print("UI Siap! Sekarang bisa di-drag dan di-klik.")
