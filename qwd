local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- [[ 1. OPTIMIZED REMOTE FINDER ]] --
local function GetAttackRemote()
    -- Mencari remote attack secara dinamis agar tidak Infinite Yield
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v.Name == "Attack" and v:IsA("RemoteEvent") then
            return v
        end
    end
end

local function GetCommF()
    return ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_")
end

