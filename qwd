local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")
local TweenService = game:GetService("TweenService")

-- [[ 1. RESET & CLEANUP ]] --
_G.AA = false
_G.Fly = false
_G.Quest = false

local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
if PlayerGui:FindFirstChild("YutaHub_Floating") then PlayerGui.YutaHub_Floating:Destroy() end

-- [[ 2. SETUP UI UTAMA ]] --
local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "YutaHub_Floating"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 50, 0, 50) -- Mulai sebagai bulat (50x50)
MainFrame.Position = UDim2.new(0.5, -25, 0.2, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.ClipsDescendants = true

local UICorner = Instance.new("UICorner", MainFrame)
UICorner.CornerRadius = UDim.new(1, 0) -- Bulat Sempurna

-- Handle Click & Drag
local ClickButton = Instance.new("TextButton", MainFrame)
ClickButton.Size = UDim2.new(1, 0, 0, 50)
ClickButton.BackgroundTransparency = 1
ClickButton.Text = "Y" -- Logo awal
ClickButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ClickButton.Font = Enum.Font.SourceSansBold
ClickButton.TextSize = 20

-- Wadah Tombol (Isi Menu)
local ContentFrame = Instance.new("Frame", MainFrame)
ContentFrame.Size = UDim2.new(1, 0, 1, -50)
ContentFrame.Position = UDim2.new(0, 0, 0, 50)
ContentFrame.BackgroundTransparency = 1
ContentFrame.Visible = false

local Layout = Instance.new("UIListLayout", ContentFrame)
Layout.Padding = UDim.new(0, 7)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

-- [[ 3. SISTEM DRAG & TWEEN (BUKA/TUTUP) ]] --
local dragging, dragStart, startPos
local isMenuOpen = false

ClickButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
        -- Jika tidak digeser jauh, maka dianggap KLIK untuk Buka/Tutup
        local delta = (input.Position - dragStart).Magnitude
        if delta < 5 then
            isMenuOpen = not isMenuOpen
            if isMenuOpen then
                -- Menjadi KOTAK MENU
                TweenService:Create(MainFrame, TweenInfo.new(0.3), {Size = UDim2.new(0, 160, 0, 260)}):Play()
                TweenService:Create(UICorner, TweenInfo.new(0.3), {CornerRadius = UDim.new(0, 10)}):Play()
                ClickButton.Text = "YUTA HUB 1"
                ContentFrame.Visible = true
            else
                -- Menjadi BULAT KEMBALI
                ContentFrame.Visible = false
                TweenService:Create(MainFrame, TweenInfo.new(0.3), {Size = UDim2.new(0, 50, 0, 50)}):Play()
                TweenService:Create(UICorner, TweenInfo.new(0.3), {CornerRadius = UDim.new(1, 0)}):Play()
                ClickButton.Text = "Y"
            end
        end
    end
end)

-- [[ 4. FUNGSI TOMBOL FITUR ]] --
local function CreateButton(name, order, callback)
    local btn = Instance.new("TextButton", ContentFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.LayoutOrder = order
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.Text = name .. (active and ": ON" or ": OFF")
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
        task.spawn(function() callback(active) end)
    end)
end

-- [[ 5. LOGIKA SAKTI SIGMA ]] --
local function GetBladeHits()
    local t = {}
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return t end
    for _, folder in pairs({workspace:FindFirstChild("Enemies"), workspace:FindFirstChild("Characters")}) do
        if folder then
            for _, v in pairs(folder:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    if (v.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude < 70 then
                        table.insert(t, v)
                    end
                end
            end
        end
    end
    return t
end

local function AttackAll()
    pcall(function()
        local enemies = GetBladeHits()
        if #enemies > 0 then
            local net = ReplicatedStorage.Modules.Net
            net["RE/RegisterAttack"]:FireServer(0)
            local hitData = {nil, {}}
            for i, v in pairs(enemies) do
                if not hitData then hitData = v.HumanoidRootPart end
                hitData[i] = {v, v.HumanoidRootPart}
            end
            net["RE/RegisterHit"]:FireServer(unpack(hitData))
        end
    end)
end

local function GetQuestData()
    local lv = LocalPlayer.Data.Level.Value
    if lv < 10 then return "BanditQuest1", 1
    elseif lv < 15 then return "MonkeyQuest1", 1
    elseif lv < 30 then return "MonkeyQuest1", 2
    else return "BanditQuest1", 1 end
end

-- [[ 6. ISI MENU ]] --
CreateButton("Auto Attack", 1, function(state)
    _G.AA = state
    while _G.AA do
        RunService.Heartbeat:Wait()
        if _G.AA then AttackAll() end
    end
end)

CreateButton("Fly Above NPC", 2, function(state)
    _G.Fly = state
    while _G.Fly do
        RunService.Heartbeat:Wait()
        pcall(function()
            local folder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Characters")
            for _, v in pairs(folder:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)
                    break
                end
            end
        end)
    end
end)

CreateButton("Auto Quest", 3, function(state)
    _G.Quest = state
    local CommF = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_")
    while _G.Quest do
        task.wait(1)
        if not LocalPlayer.PlayerGui.Main.Quest.Visible then
            local qName, qId = GetQuestData()
            CommF:InvokeServer("StartQuest", qName, qId)
        end
    end
end)

