local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

_G.KillAura = true
_G.Range = 40 -- Jarak aman agar tidak terdeteksi bypass

task.spawn(function()
    while _G.KillAura do
        task.wait(0.1)
        pcall(function()
            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool then
                -- Cari musuh di folder Enemies
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        local root = v:FindFirstChild("HumanoidRootPart")
                        if root then
                            local dist = (root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                            if dist < _G.Range then
                                -- Serang tanpa teleport NPC (Lebih Aman)
                                tool:Activate()
                                -- Fast Attack (Hapus animasi)
                                local anims = LocalPlayer.Character.Humanoid:GetPlayingAnimationTracks()
                                for i=1, #anims do anims[i]:Stop() end
                            end
                        end
                    end
                end
            end
        end)
    end
end)
