-- [[ 2. DATA QUEST SEMUA LEVEL (SEA 1) ]] --
local function GetQuestData()
    local lv = LocalPlayer.Data.Level.Value
    if lv < 10 then return "BanditQuest1", 1
    elseif lv < 15 then return "MonkeyQuest1", 1
    elseif lv < 30 then return "MonkeyQuest1", 2
    elseif lv < 40 then return "PirateIslandQuest", 1
    elseif lv < 60 then return "PirateIslandQuest", 2
    elseif lv < 75 then return "DesertIslandQuest", 1
    elseif lv < 90 then return "DesertIslandQuest", 2
    elseif lv < 120 then return "SnowIslandQuest", 1
    elseif lv < 150 then return "SnowIslandQuest", 2
    elseif lv < 175 then return "MarineTreeQuest", 1
    elseif lv < 190 then return "MarineTreeQuest", 2
    elseif lv < 210 then return "SkyQuest", 1
    elseif lv < 250 then return "SkyQuest", 2
    elseif lv < 275 then return "PrisonQuest", 1
    elseif lv < 300 then return "PrisonQuest", 2
    elseif lv < 330 then return "MagmaQuest", 1
    elseif lv < 425 then return "MagmaQuest", 2
    elseif lv < 450 then return "FishmanQuest", 1
    elseif lv < 575 then return "FishmanQuest", 2
    elseif lv < 625 then return "SkyExp1Quest", 1
    elseif lv < 700 then return "SkyExp1Quest", 2
    else return "BanditQuest1", 1 end
end

-- [[ 3. LOGIKA FAST ATTACK (GABUNGAN SIGMA 1 & 2) ]] --

-- Fungsi Cari Target Banyak (Multi-Target)
local function GetBladeHits()
    local t = {}
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return t end
    for _, folder in pairs({workspace:FindFirstChild("Enemies"), workspace:FindFirstChild("Characters")}) do
        if folder then
            for _, v in pairs(folder:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                    if (v.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude < 70 then
                        table.insert(t, v)
                    end
                end
            end
        end
    end
    return t
end

-- Otak Serangan (Ultra Speed)
local function AttackAll()
    pcall(function()
        local ch = LocalPlayer.Character
        local tool = ch and ch:FindFirstChildOfClass("Tool")
        if not tool then return end
        
        local enemies = GetBladeHits()
        if #enemies > 0 then
            local net = ReplicatedStorage.Modules.Net
            -- Metode Sigma 2: Register Hit (Multi-Damage)
            net["RE/RegisterAttack"]:FireServer(0)
            
            local hitData = {nil, {}}
            for i, v in pairs(enemies) do
                if not hitData[1] then hitData[1] = v.HumanoidRootPart end
                hitData[2][i] = {v, v.HumanoidRootPart}
            end
            net["RE/RegisterHit"]:FireServer(unpack(hitData))
            
            -- Metode Sigma 1: Spam Remote Attack (Bonus Damage)
            net["RE/Attack"]:FireServer(0.12)
            
            -- Animasi Klik (Bypass Visual)
            VirtualUser:CaptureController()
            VirtualUser:ClickButton1(Vector2.new(0,0))
        end
    end)
end

