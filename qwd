    while _G.AA do
        RunService.Heartbeat:Wait()
        if _G.AA then AttackAll() end
    end
end)

-- FLY ABOVE NPC (Tinggi 10)
CreateButton("Fly Above NPC", 2, function(state)
    _G.Fly = state
    while _G.Fly do
        RunService.Heartbeat:Wait()
        pcall(function()
            local folder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Characters")
            for _, v in pairs(folder:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)
                    break
                end
            end
        end)
    end
end)

-- AUTO QUEST (Smart)
CreateButton("Auto Quest", 3, function(state)
    _G.Quest = state
    while _G.Quest do
        task.wait(1.5)
        pcall(function()
            local comm = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_")
            if comm and not LocalPlayer.PlayerGui.Main.Quest.Visible then
                local qName, qId = GetQuestData()
                comm:InvokeServer("StartQuest", qName, qId)
            end
        end)
    end
end)

