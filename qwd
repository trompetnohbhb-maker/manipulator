local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local function hideEverything()
    local char = player.Character
    if char then
        for _, v in pairs(char:GetDescendants()) do
            -- Menghilangkan SelectionBox (Garis kotak Ken Haki)
            if v:IsA("SelectionBox") or v:IsA("BoxHandleAdornment") then
                v.Visible = false
            end
            
            -- Menghilangkan Efek Aura Cahaya
            if v:IsA("PointLight") or v:IsA("SurfaceLight") or v:IsA("SpotLight") then
                v.Enabled = false
            end

            -- Menghilangkan Partikel & Trail
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                v.Enabled = false
            end

            -- Tetap menjaga badan transparan (0.99 agar tidak speed glitch)
            if v:IsA("BasePart") or v:IsA("MeshPart") then
                if v.Name ~= "HumanoidRootPart" then
                    v.Transparency = 0.99
                end
            end

            -- Hapus Aksesoris yang sering muncul lagi saat ganti mode
            if v:IsA("Accessory") then
                v:Destroy()
            end
        end
    end
end

runService.RenderStepped:Connect(hideEverything)
print("Invis Ken Haki Aktif! Aura dan kotak deteksi sekarang hilang.")
