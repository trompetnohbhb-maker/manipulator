                tool.Handle.Size = _G.AttackRange and Vector3.new(65, 65, 65) or Vector3.new(1,1,1)
                tool.Handle.Transparency = 0.8
                tool.Handle.CanCollide = false
            end
        end
    end)
end)

-- C. FLY ABOVE NPC
CreateButton("Fly Above NPC", 3, function(state)
    _G.FlyAbove = state
    task.spawn(function()
        while _G.FlyAbove do
            RunService.Heartbeat:Wait()
            local target = GetEnemy()
            if target and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)
            end
        end)
    end)
end)

-- D. AUTO QUEST (SMART LEVEL)
CreateButton("Auto Quest", 4, function(state)
    _G.AutoQuest = state
    task.spawn(function()
        local comm = ReplicatedStorage.Remotes:FindFirstChild("CommF_")
        while _G.AutoQuest do
            if comm and not LocalPlayer.PlayerGui.Main.Quest.Visible then
                local qName, qId = GetQuestData()
                comm:InvokeServer("StartQuest", qName, qId)
            end
            task.wait(2)
        end
    end)
end)
