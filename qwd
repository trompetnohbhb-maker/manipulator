local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

_G.KillAura = true -- Set ke false untuk mematikan
_G.AttackRange = 50 -- Jarak jangkauan pukul

task.spawn(function()
    while _G.KillAura do
        task.wait(0.1) -- Jeda agar tidak mudah kena kick
        pcall(function()
            local char = LocalPlayer.Character
            local tool = char and char:FindFirstChildOfClass("Tool")
            
            if tool then
                -- Mencari NPC terdekat
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    local humanoid = v:FindFirstChild("Humanoid")
                    local root = v:FindFirstChild("HumanoidRootPart")
                    
                    if humanoid and root and humanoid.Health > 0 then
                        local dist = (root.Position - char.HumanoidRootPart.Position).Magnitude
                        if dist < _G.AttackRange then
                            -- Menyerang otomatis (Kill Aura)
                            tool:Activate()
                            -- Logic Fast Attack (Hapus animasi cooldown)
                            for _, anim in pairs(char.Humanoid:GetPlayingAnimationTracks()) do
                                anim:Stop()
                            end
                        end
                    end
                end
            end
        end)
    end
end)

print("Kill Aura & Fast Attack Aktif!")
