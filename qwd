local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Wadah UI
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "FinalFinder"
ScreenGui.ResetOnSpawn = false

local function beriESP(root, pName)
    if root:FindFirstChild("KotakESP") then return end
    
    local gui = Instance.new("BillboardGui", root)
    gui.Name = "KotakESP"
    gui.AlwaysOnTop = true
    gui.Size = UDim2.new(4, 0, 5.5, 0)
    
    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 0.5
    frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    Instance.new("UIStroke", frame).Color = Color3.fromRGB(255, 255, 255)

    -- Tracers (Garis)
    local line = Instance.new("Frame", ScreenGui)
    line.BorderSizePixel = 0
    line.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    line.AnchorPoint = Vector2.new(0.5, 0.5)

    RunService.RenderStepped:Connect(function()
        if root and root.Parent then
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                local start = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                local endP = Vector2.new(pos.X, pos.Y)
                line.Visible = true
                line.Size = UDim2.new(0, 1.5, 0, (start - endP).Magnitude)
                line.Position = UDim2.new(0, (start.X + endP.X)/2, 0, (start.Y + endP.Y)/2)
                line.Rotation = math.deg(math.atan2(endP.Y - start.Y, endP.X - start.X)) - 90
            else
                line.Visible = false
            end
        else
            line:Destroy()
        end
    end)
end

-- LOOP BRUTAL: Cari nama player di seluruh Workspace
task.spawn(function()
    while task.wait(1) do
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                -- Cari objek di Workspace yang namanya sama dengan Player
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj.Name == p.Name or (obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj.Name ~= LocalPlayer.Name) then
                        local part = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head") or obj:FindFirstChildOfClass("Part")
                        if part then
                            beriESP(part, p.Name)
                        end
                    end
                end
            end
        end
    end
end)
