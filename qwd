local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- KONFIGURASI
local FOV_JARAK = 100 -- Seberapa dekat musuh harus ada di layar biar kekunci

-- [[ 1. ESP STABIL (LOGIKA ASLI KAMU - PASTI WORK) ]] --
local function buatESP(player)
    player.CharacterAdded:Connect(function(char)
        if player == LocalPlayer then return end
        local root = char:WaitForChild("HumanoidRootPart", 10) 
        if root then
            if root:FindFirstChild("KotakESP") then root.KotakESP:Destroy() end
            local gui = Instance.new("BillboardGui", root)
            gui.Name = "KotakESP"
            gui.AlwaysOnTop = true
            gui.Size = UDim2.new(4, 0, 5.5, 0)
            local frame = Instance.new("Frame", gui)
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 0.6
            frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            local stroke = Instance.new("UIStroke", frame)
            stroke.Thickness = 2
            stroke.Color = Color3.fromRGB(255, 255, 255)
        end
    end)
end

-- [[ 2. LOGIKA AUTO-LOCK (STABIL & INSTAN) ]] --
RunService.RenderStepped:Connect(function()
    local target = nil
    local shortestDistance = FOV_JARAK
    local mousePos = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2) -- Tengah layar

    -- Mencari musuh terdekat dari tengah layar
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
            local head = player.Character.Head
            local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
            
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                if distance < shortestDistance then
                    target = head
                    shortestDistance = distance
                end
            end
        end
    end

    -- PAKSA NEMPEL (Tanpa syarat klik)
    if target then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
    end
end)

-- Jalankan ESP awal
for _, p in pairs(Players:GetPlayers()) do
    if p.Character then buatESP(p) end
    buatESP(p)
end
Players.PlayerAdded:Connect(buatESP)
