-- 1. AUTO ATTACK (Blox Fruits)
local FastAttackEnabled = false
CreateButton("Auto Attack", 1, function(state)
    FastAttackEnabled = state
    if FastAttackEnabled then
        task.spawn(function()
            while FastAttackEnabled do
                local char = LocalPlayer.Character
                local tool = char and char:FindFirstChildOfClass("Tool")
                
                if tool then
                    -- Kirim sinyal serang 3x sekaligus (Sangat Cepat)
                    AttackRemote:FireServer(0.1)
                    AttackRemote:FireServer(0.1)
                    AttackRemote:FireServer(0.1)
                    
                    -- Jalankan animasi pukul
                    tool:Activate()
                end
                task.wait(0.1) -- Jeda aman agar tidak error
            end
        end)
    end
end)

