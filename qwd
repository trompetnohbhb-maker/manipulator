    end)
end)

-- ATTACK RANGE (Hitbox Expander)
CreateButton("Attack Range", 2, function(state)
    _G.AttackRange = state
    task.spawn(function()
        while _G.AttackRange do
            task.wait(1)
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChild("Handle") then
                    tool.Handle.Size = Vector3.new(65, 65, 65)
                    tool.Handle.Transparency = 0.8
                    tool.Handle.CanCollide = false
                end
            end)
        end
    end)
end)

-- FLY ABOVE NPC (Tinggi 8 - Jarak Ideal Hitbox)
CreateButton("Fly Above NPC", 3, function(state)
    _G.FlyAbove = state
    task.spawn(function()
        while _G.FlyAbove do
            RunService.Heartbeat:Wait()
            pcall(function()
                -- Cari musuh terdekat
                local target = nil
                local dist = 500
                local folder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Characters")
                for _, v in pairs(folder:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        local mag = (v.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                        if mag < dist then dist = mag; target = v end
                    end
                end
                
                if target and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 8, 0)
                end
            end)
        end
    end)
end)

