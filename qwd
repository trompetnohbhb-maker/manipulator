local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function buatESP(player)
    player.CharacterAdded:Connect(function(char)
        if player == LocalPlayer then return end
        
        -- Bypass "Asset not found" dengan menunggu part muncul (max 10 detik)
        local root = char:WaitForChild("HumanoidRootPart", 10) 
        
        if root then
            -- Cek jika sudah ada ESP agar tidak tumpuk
            if root:FindFirstChild("KotakESP") then return end

            local gui = Instance.new("BillboardGui")
            gui.Name = "KotakESP"
            gui.AlwaysOnTop = true
            gui.Size = UDim2.new(4, 0, 5.5, 0)
            gui.Adornee = root
            gui.Parent = root

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 0.6
            frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Warna MERAH
            frame.BorderSizePixel = 0
            frame.Parent = gui
            
            -- Tambah garis tepi biar kelihatan jelas
            local stroke = Instance.new("UIStroke")
            stroke.Thickness = 2
            stroke.Color = Color3.fromRGB(255, 255, 255)
            stroke.Parent = frame
        end
    end)
end

-- Jalankan untuk semua pemain yang sudah ada
for _, p in pairs(Players:GetPlayers()) do
    if p.Character then
        task.spawn(function()
            local char = p.Character
            local root = char:WaitForChild("HumanoidRootPart", 5)
            if root and p ~= LocalPlayer and not root:FindFirstChild("KotakESP") then
                local gui = Instance.new("BillboardGui")
                gui.Name = "KotakESP"
                gui.AlwaysOnTop = true
                gui.Size = UDim2.new(4, 0, 5.5, 0)
                gui.Adornee = root
                gui.Parent = root
                
                local frame = Instance.new("Frame")
                frame.Size = UDim2.new(1, 0, 1, 0)
                frame.BackgroundTransparency = 0.6
                frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                frame.Parent = gui
            end
        end)
    end
    buatESP(p)
end

Players.PlayerAdded:Connect(buatESP)
