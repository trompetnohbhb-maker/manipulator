local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- Variabel kontrol
local espAktif = true
local tombolKeybind = Enum.KeyCode.P -- Ganti "P" sesuai keinginan

local function buatESP(player)
    player.CharacterAdded:Connect(function(char)
        if player == LocalPlayer then return end
        
        -- Menunggu part muncul agar tidak "Asset not found"
        local root = char:WaitForChild("HumanoidRootPart", 10) 
        
        if root then
            if root:FindFirstChild("KotakESP") then root.KotakESP:Destroy() end

            local gui = Instance.new("BillboardGui")
            gui.Name = "KotakESP"
            gui.AlwaysOnTop = true
            gui.Size = UDim2.new(4, 0, 5.5, 0)
            gui.Adornee = root
            gui.Enabled = espAktif -- Tergantung status ON/OFF
            gui.Parent = root

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 0.6
            frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            frame.BorderSizePixel = 0
            frame.Parent = gui
            
            local stroke = Instance.new("UIStroke")
            stroke.Thickness = 2
            stroke.Color = Color3.fromRGB(255, 255, 255)
            stroke.Parent = frame
        end
    end)
end

-- Fungsi Keybind untuk ON/OFF
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == tombolKeybind then
        espAktif = not espAktif
        -- Update semua ESP yang sudah muncul di map
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local root = p.Character.HumanoidRootPart
                local gui = root:FindFirstChild("KotakESP")
                if gui then
                    gui.Enabled = espAktif
                end
            end
        end
    end
end)

-- Jalankan untuk pemain yang sudah ada di server
for _, p in pairs(Players:GetPlayers()) do
    if p.Character then
        task.spawn(function()
            local root = p.Character:WaitForChild("HumanoidRootPart", 5)
            if root and p ~= LocalPlayer then
                buatESP(p) -- Panggil fungsi utama agar logika sama
                -- Trigger manual untuk karakter yang sudah ada
                p.CharacterAdded:Connect(function() buatESP(p) end)
            end
        end)
    end
    buatESP(p)
end

Players.PlayerAdded:Connect(buatESP)
print("ESP Berhasil Dimuat! Tekan P untuk ON/OFF")
