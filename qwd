-- C. Fly Above NPC (Stability Fix)
CreateButton("Fly Above NPC", 3, function(state)
    _G.Fly = state
    task.spawn(function()
        while _G.Fly do
            pcall(function()
                local enemy = GetNearestEnemy()
                if enemy and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    -- Mengunci posisi agar tidak goyang
                    LocalPlayer.Character.HumanoidRootPart.CFrame = enemy.HumanoidRootPart.CFrame * CFrame.new(0, 8, 0)
                end
            end)
            task.wait()
        end
    end)
end)

-- D. Auto Quest (Smart Selection)
local function GetMyQuest()
    local lv = LocalPlayer.Data.Level.Value
    if lv < 10 then return "BanditQuest1", 1
    elseif lv < 15 then return "MonkeyQuest1", 1
    elseif lv < 30 then return "MonkeyQuest1", 2
    else return "BanditQuest1", 1 end
end

CreateButton("Auto Quest", 4, function(state)
    _G.AutoQuest = state
    task.spawn(function()
        local comm = GetCommF()
        while _G.AutoQuest do
            if comm and (not LocalPlayer.PlayerGui.Main.Quest.Visible) then
                local name, id = GetMyQuest()
                comm:InvokeServer("StartQuest", name, id)
            end
            task.wait(1.5)
        end
    end)
end)

