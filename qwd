-- ATTACK RANGE (Hitbox Method - Lebih stabil dari Mob Pull)
_G.Range = false
CreateButton("Attack Range", 2, function(state)
    _G.Range = state
    while _G.Range do
        task.wait(0.5)
        pcall(function()
            local enemy = GetTarget()
            if enemy and _G.Range then
                enemy.HumanoidRootPart.Size = Vector3.new(30, 30, 30)
                enemy.HumanoidRootPart.Transparency = 0.8
                enemy.HumanoidRootPart.CanCollide = false
            end
        end)
    end
end)

-- FLY ABOVE NPC (Tinggi 10 unit / 3 NPC)
_G.Fly = false
CreateButton("Fly Above NPC", 3, function(state)
    _G.Fly = state
    while _G.Fly do
        task.wait()
        pcall(function()
            local target = GetTarget()
            if target and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                -- Teleport pas 10 unit di atas target
                LocalPlayer.Character.HumanoidRootPart.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)
            end
        end)
    end
end)

