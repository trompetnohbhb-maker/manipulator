local Player = game.Players.LocalPlayer
local Character = Player.Character
local Root = Character.HumanoidRootPart

-- Simpan posisi asli biar bisa jalan
local Pos = Root.CFrame

-- LOGIKA: Kirim badan asli ke bawah map (Server Side Bypass)
-- Di layar orang lain, kamu ada di bawah tanah, jadi gak bisa disentuh/dilihat
task.spawn(function()
    while task.wait() do
        if Character:FindFirstChild("Humanoid") then
            -- Membuat karakter seolah-olah "mati" tapi tetap hidup
            Character.Humanoid:ChangeState(11) 
        end
    end
end)

-- Menghilangkan bagian tubuh secara paksa
for _, v in pairs(Character:GetDescendants()) do
    if v:IsA("BasePart") then
        v.Transparency = 1
        v.CanCollide = false
    end
end

print("FE Invisible Aktif! Badan asli kamu sekarang aman di bawah tanah.")
