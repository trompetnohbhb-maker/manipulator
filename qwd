-- AUTO ATTACK (Bypass Method)
CreateButton("Auto Attack", 1, function(state)
    _G.AutoAttack = state
    task.spawn(function()
        local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
        local AttackRE = Net:WaitForChild("RE"):WaitForChild("Attack")
        
        while _G.AutoAttack do
            RunService.RenderStepped:Wait()
            pcall(function()
                local Tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                local Enemy = GetEnemy()
                if Tool and Enemy then
                    -- BYPASS: Kirim data hit langsung ke musuh terdekat
                    AttackRE:FireServer(0.1) -- Argumen kecepatan
                    Tool:Activate() -- Animasi pendukung
                end
            end)
        end
    end)
end)

-- ATTACK RANGE (Hitbox Expander)
CreateButton("Attack Range", 2, function(state)
    _G.AttackRange = state
    task.spawn(function()
        while _G.AttackRange do
            task.wait(0.5)
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChild("Handle") then
                    tool.Handle.Size = Vector3.new(65, 65, 65)
                    tool.Handle.Transparency = 0.8
                    tool.Handle.CanCollide = false
                end
            end)
        end
    end)
end)

-- FLY ABOVE NPC (Tinggi 10 unit)
CreateButton("Fly Above NPC", 3, function(state)
    _G.FlyAbove = state
    task.spawn(function()
        while _G.FlyAbove do
            RunService.Heartbeat:Wait()
            pcall(function()
                local Enemy = GetEnemy()
                if Enemy and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = Enemy.HumanoidRootPart.CFrame * CFrame.new(0, 20, 0)
                end
            end)
        end
    end)
end)

-- AUTO QUEST (Bandit)
CreateButton("Auto Quest", 4, function(state)
    _G.AutoQuest = state
    task.spawn(function()
        local comm = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_")
