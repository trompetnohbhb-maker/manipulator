local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")

-- SETTING KEDALAMAN (Makin gede angkanya, makin dalem tenggelamnya)
local kedalaman = 7 

-- 1. Membuat karakter tenggelam tapi tetap bisa jalan
hum.HipHeight = -kedalaman

-- 2. Mematikan tabrakan agar tidak mental saat gesek lantai
local runService = game:GetService("RunService")
runService.Stepped:Connect(function()
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CanCollide = false
        end
    end
end)

print("Tenggelam aktif! Kamu bisa jalan di bawah lantai sekarang.")
