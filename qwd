local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")

-- Wadah Utama
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "RonixBlox_Fixed"
ScreenGui.ResetOnSpawn = false

-- [[ 1. MAIN FRAME ]] --
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 160, 0, 220)
MainFrame.Position = UDim2.new(0.1, 0, 0.3, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.ClipsDescendants = true 

local UICorner = Instance.new("UICorner", MainFrame)
UICorner.CornerRadius = UDim.new(0, 8)

-- [[ 2. HEADER / TOMBOL DRAG & CLICK ]] --
local TitleBtn = Instance.new("TextButton", MainFrame)
TitleBtn.Size = UDim2.new(1, 0, 0, 35)
TitleBtn.Text = "DRAG ME (Click)"
TitleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
TitleBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
TitleBtn.Font = Enum.Font.SourceSansBold
TitleBtn.TextSize = 14
TitleBtn.AutoButtonColor = false

local HeaderCorner = Instance.new("UICorner", TitleBtn)
HeaderCorner.CornerRadius = UDim.new(0, 8)

-- [[ 3. SISTEM DRAG (Ditaruh di TitleBtn) ]] --
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

TitleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TitleBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- [[ 4. ISI MENU & COLLAPSE ]] --
local ContentFrame = Instance.new("Frame", MainFrame)
ContentFrame.Size = UDim2.new(1, 0, 1, -40)
ContentFrame.Position = UDim2.new(0, 0, 0, 40)
ContentFrame.BackgroundTransparency = 1

local Layout = Instance.new("UIListLayout", ContentFrame)
Layout.Padding = UDim.new(0, 5)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

local collapsed = false
TitleBtn.MouseButton1Click:Connect(function()
    collapsed = not collapsed
    if collapsed then
        MainFrame:TweenSize(UDim2.new(0, 160, 0, 35), "Out", "Quad", 0.3, true)
        ContentFrame.Visible = false
    else
        MainFrame:TweenSize(UDim2.new(0, 160, 0, 220), "Out", "Quad", 0.3, true)
        ContentFrame.Visible = true
    end
end)

local function CreateButton(name, order, callback)
    local btn = Instance.new("TextButton", ContentFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.LayoutOrder = order
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 13
    Instance.new("UICorner", btn)

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.Text = name .. (active and ": ON" or ": OFF")
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
        callback(active) -- Jalankan fungsi saat tombol dipencet
    end)
end

-- [[ 5. TEMPAT ISI LOGIKA SCRIPT ]] --

CreateButton("Auto Attack", 1, function(state)
    if state then
        print("Auto Attack Aktif")
        -- Masukkan script serang di sini
    else
        print("Auto Attack Mati")
    end
end)

CreateButton("Attack Range", 2, function(state)
