local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- KONFIGURASI
local FOV_RADIUS = 200 
local AIM_PART = "Head"
local AIM_SMOOTHNESS = 1 -- Langsung nempel (Instan)

-- [[ 1. BUAT LINGKARAN FOV PAKAI GUI (PASTI MUNCUL) ]] --
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "FOVScreen"
ScreenGui.ResetOnSpawn = false

local FOVFrame = Instance.new("Frame", ScreenGui)
FOVFrame.Name = "FOVCircle"
FOVFrame.Size = UDim2.new(0, FOV_RADIUS * 2, 0, FOV_RADIUS * 2)
FOVFrame.AnchorPoint = Vector2.new(0.5, 0.5)
FOVFrame.BackgroundTransparency = 1
FOVFrame.BorderSizePixel = 0

local UIStroke = Instance.new("UIStroke", FOVFrame)
UIStroke.Thickness = 2
UIStroke.Color = Color3.fromRGB(255, 255, 255) 

local UICorner = Instance.new("UICorner", FOVFrame)
UICorner.CornerRadius = UDim.new(1, 0)

-- [[ 2. ESP STABIL (LOGIKA ASLI KAMU) ]] --
local function buatESP(player)
    player.CharacterAdded:Connect(function(char)
        if player == LocalPlayer then return end
        local root = char:WaitForChild("HumanoidRootPart", 10) 
        if root then
            if root:FindFirstChild("KotakESP") then root.KotakESP:Destroy() end
            local gui = Instance.new("BillboardGui", root)
            gui.Name = "KotakESP"
            gui.AlwaysOnTop = true
            gui.Size = UDim2.new(4, 0, 5.5, 0)
            local frame = Instance.new("Frame", gui)
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 0.6
            frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            local stroke = Instance.new("UIStroke", frame)
            stroke.Thickness = 2
            stroke.Color = Color3.fromRGB(255, 255, 255)
        end
    end)
end

-- [[ 3. LOGIKA AUTO-LOCK AIM ]] --
local function getClosestPlayer()
    local target = nil
    local shortestDistance = FOV_RADIUS
    local mousePos = UserInputService:GetMouseLocation()

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(AIM_PART) then
            local part = player.Character[AIM_PART]
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                if distance < shortestDistance then
                    target = part
                    shortestDistance = distance
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    -- Update posisi lingkaran ke kursor
    local mousePos = UserInputService:GetMouseLocation()
    FOVFrame.Position = UDim2.new(0, mousePos.X, 0, mousePos.Y)

    -- AUTO-LOCK LOGIC (Selalu ngikutin musuh di FOV)
    local target = getClosestPlayer()
    if target then
        -- Kamera dipaksa melihat ke target secara instan
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
    end
end)

-- Jalankan ESP
for _, p in pairs(Players:GetPlayers()) do
    if p.Character then buatESP(p) end
    buatESP(p)
end
Players.PlayerAdded:Connect(buatESP)
